# Anthropic
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
# claude-opus-4-7 matches the plan ($5/$25 per 1M; claude-opus-4-8 is the same
# price and more capable). The deployed default is claude-haiku-4-5 ($1/$5 per
# 1M, cache reads $0.10/1M) for cost: see render.yaml. Haiku requires
# ANTHROPIC_EFFORT=none and has a 200k context (vs 1M on Opus 4.7+).
ANTHROPIC_MODEL=claude-haiku-4-5
# Optional. Opus 4.6+ use adaptive thinking + an effort knob (not temperature):
# low | medium | high | max ("high" is the default). "none" omits the thinking
# and effort params entirely — REQUIRED for claude-haiku-4-5, which 400s on both.
ANTHROPIC_EFFORT=none

# Site auth (single shared password for the MVP)
SITE_PASSWORD=choose-a-strong-shared-secret

# Per-conversation safety caps (the request-level backstop to the monthly cap).
# On claude-haiku-4-5 the values below bound one /chat request at ~$0.50 even
# in the adversarial worst case (every cap + the 200k context saturated on
# every loop iteration); a realistic question costs $0.05-0.15 warm-cache.
MAX_CONVERSATION_INPUT_TOKENS=200000
MAX_TOOL_CALLS_PER_TURN=6
# Optional. Max output tokens per model call (kept well under the SDK's
# non-streaming HTTP-timeout threshold for the MVP).
MAX_OUTPUT_TOKENS=2500

# In-memory per-IP rate limit (the leaked-password backstop; single-instance only)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# Weights & Biases (Phase 2, report authoring only)
WANDB_API_KEY=REPLACE_ME
WANDB_ENTITY=your-wandb-entity
WANDB_SOURCE_PROJECT=your-frozen-canonical-project
WANDB_TARGET_PROJECT=thesis-visitor-reports

# Runtime
PORT=8080
NODE_ENV=development
