# Anthropic
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
# claude-opus-4-7 matches the plan. claude-opus-4-8 is current at the same price
# ($5/$25 per 1M, 1M context) and more capable — a config-only swap, no redeploy.
ANTHROPIC_MODEL=claude-opus-4-7
# Optional. Opus 4.7/4.8 use adaptive thinking + an effort knob (not temperature):
# low | medium | high | max. effort is the biggest cost lever; "high" is the default.
ANTHROPIC_EFFORT=high

# Site auth (single shared password for the MVP)
SITE_PASSWORD=choose-a-strong-shared-secret

# Per-conversation safety caps (the request-level backstop to the monthly cap)
MAX_CONVERSATION_INPUT_TOKENS=200000
MAX_TOOL_CALLS_PER_TURN=20
# Optional. Max output tokens per model call (kept well under the SDK's
# non-streaming HTTP-timeout threshold for the MVP).
MAX_OUTPUT_TOKENS=8192

# In-memory per-IP rate limit (the leaked-password backstop; single-instance only)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# Weights & Biases (Phase 2, report authoring only)
WANDB_API_KEY=REPLACE_ME
WANDB_ENTITY=your-wandb-entity
WANDB_SOURCE_PROJECT=your-frozen-canonical-project
WANDB_TARGET_PROJECT=thesis-visitor-reports

# Runtime
PORT=8080
NODE_ENV=development
