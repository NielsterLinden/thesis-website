# Normalize all text to LF in the repo and on checkout. The app is built and
# deployed in a Linux container; consistent LF avoids CRLF creeping into shell
# scripts, the Dockerfile, or config and breaking inside the image.
* text=auto eol=lf

# Binary assets — never normalize.
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.h5 binary

# Frozen data exports: keep byte-identical to the original W&B export (it ships
# with CRLF line endings). Do not normalize, so the file stays checksummable.
*.csv -text
